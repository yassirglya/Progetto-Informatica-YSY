{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Traffic Simulator",
            "type": "gdb",
            "request": "launch",
            "program": "${workspaceFolder}/traffic_simulator/traffic_simulator",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/traffic_simulator",
            "externalConsole": true,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "make: build"
        }
    ]
}
